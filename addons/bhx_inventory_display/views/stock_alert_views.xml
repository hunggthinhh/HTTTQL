<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM -->
    <record id="view_stock_alert_form" model="ir.ui.view">
        <field name="name">bhx.stock.alert.form</field>
        <field name="model">bhx.stock.alert</field>
        <field name="arch" type="xml">
            <form string="Cảnh báo tồn kho">
                <header>
                    <button name="action_add_to_replenishment" string="Tạo đợt châm hàng"
                            type="object" class="btn-primary" invisible="state in ('resolved', 'ignored')"/>
                    <button name="action_create_import_order" string="Tạo phiếu nhập hàng"
                            type="object" class="btn-info" invisible="state in ('resolved', 'ignored')"/>
                    <button name="action_processing" string="Bắt đầu xử lý"
                            type="object" class="btn-primary" invisible="state != 'new'"/>
                    <button name="action_resolved" string="Đã xử lý xong"
                            type="object" class="btn-success" invisible="state != 'processing'"/>
                    <button name="action_ignore" string="Bỏ qua"
                            type="object" invisible="state not in ('new', 'processing')"/>
                    <button name="action_reopen" string="Mở lại"
                            type="object" invisible="state not in ('resolved', 'ignored')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,processing,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin cảnh báo">
                            <field name="alert_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="product_id"/>
                            <field name="warehouse_id"/>
                            <field name="lot_id"/>
                            <field name="expiry_date"/>
                            <field name="days_to_expiry"/>
                        </group>
                        <group string="Số lượng tồn kho">
                            <field name="current_qty"/>
                            <field name="min_qty"/>
                            <field name="max_qty"/>
                            <field name="responsible_id"/>
                        </group>
                    </group>
                    <group string="Hướng xử lý">
                        <field name="note" nolabel="1" placeholder="Ghi chú hướng xử lý..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- TREE -->
    <record id="view_stock_alert_tree" model="ir.ui.view">
        <field name="name">bhx.stock.alert.tree</field>
        <field name="model">bhx.stock.alert</field>
        <field name="arch" type="xml">
            <tree string="Cảnh báo tồn kho"
                  decoration-danger="alert_type in ('out_of_stock','expired') or days_to_expiry &lt; 0"
                  decoration-warning="alert_type in ('low_stock','near_expiry') or (days_to_expiry &gt;= 0 and days_to_expiry &lt;= 3)"
                  decoration-muted="state in ('resolved','ignored')">
                <field name="priority" widget="priority"/>
                <field name="name"/>
                <field name="alert_type"/>
                <field name="product_id"/>
                <field name="warehouse_id"/>
                <field name="lot_id" optional="hide"/>
                <field name="expiry_date" optional="show"/>
                <field name="days_to_expiry" optional="show"/>
                <field name="current_qty"/>
                <field name="min_qty"/>
                <field name="responsible_id"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'new'"
                       decoration-warning="state == 'processing'"
                       decoration-success="state == 'resolved'"
                       decoration-muted="state == 'ignored'"/>
                <button name="action_add_to_replenishment" string="Châm hàng" 
                        type="object" icon="fa-truck" class="btn-info"
                        invisible="state in ('resolved', 'ignored')"
                        help="Nhấn để tạo nhanh đợt châm hàng từ cảnh báo này"/>
                <button name="action_create_import_order" string="Nhập hàng" 
                        type="object" icon="fa-plus-square" class="btn-primary"
                        invisible="state in ('resolved', 'ignored')"
                        help="Nhấn để tạo nhanh phiếu nhập hàng từ cảnh báo này"/>

            </tree>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_stock_alert_search" model="ir.ui.view">
        <field name="name">bhx.stock.alert.search</field>
        <field name="model">bhx.stock.alert</field>
        <field name="arch" type="xml">
            <search string="Tìm cảnh báo tồn kho">
                <field name="name"/>
                <field name="product_id"/>
                <field name="warehouse_id"/>
                <filter string="Mới" name="new" domain="[('state','=','new')]"/>
                <filter string="Đang xử lý" name="processing" domain="[('state','=','processing')]"/>
                <filter string="Sắp hết hàng" name="low" domain="[('alert_type','=','low_stock')]"/>
                <filter string="Sắp hết hạn" name="near_expiry" domain="[('alert_type','=','near_expiry')]"/>
                <filter string="Đã hết hạn" name="expired" domain="[('alert_type','=','expired')]"/>
                <separator/>
                <filter string="Khẩn cấp" name="urgent" domain="[('priority','=','3')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Loại cảnh báo" name="group_type" context="{'group_by':'alert_type'}"/>
                    <filter string="Độ ưu tiên" name="group_prio" context="{'group_by':'priority'}"/>
                    <filter string="Cửa hàng" name="group_wh" context="{'group_by':'warehouse_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_stock_alert" model="ir.actions.act_window">
        <field name="name">Cảnh báo tồn kho</field>
        <field name="res_model">bhx.stock.alert</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_stock_alert_search"/>
        <field name="context">{'search_default_new': 1, 'search_default_processing': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Không có cảnh báo tồn kho nào!</p>
        </field>
    </record>
</odoo>
