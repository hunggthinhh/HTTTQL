<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_disposal_form_inherit_shelf" model="ir.ui.view">
        <field name="name">bhx.disposal.form.inherit.shelf</field>
        <field name="model">bhx.disposal</field>
        <field name="inherit_id" ref="bhx_audit_control.view_disposal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']/tree/field[@name='product_id']" position="after">
                <field name="display_location_id" domain="[('warehouse_id', '=', parent.warehouse_id)]"/>
            </xpath>
        </field>
    </record>
</odoo>
