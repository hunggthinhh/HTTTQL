<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM -->
    <record id="view_display_location_form" model="ir.ui.view">
        <field name="name">bhx.display.location.form</field>
        <field name="model">bhx.display.location</field>
        <field name="arch" type="xml">
            <form string="Vị trí trưng bày">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_products" type="object"
                                class="oe_stat_button" icon="fa-th-list">
                            <field name="product_count" widget="statinfo" string="Sản phẩm"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h3><field name="code"/></h3>
                    </div>
                    <group>
                        <group string="Thông tin vị trí">
                            <field name="zone"/>
                            <field name="location_type"/>
                            <field name="warehouse_id"/>
                            <field name="responsible_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Chi tiết kệ / Nhiệt độ">
                            <field name="aisle"/>
                            <field name="shelf_no"/>
                            <field name="level"/>
                            <field name="capacity"/>
                            <field name="temperature_min"/>
                            <field name="temperature_max"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sản phẩm trưng bày" name="products">
                            <field name="product_line_ids">
                                <tree editable="bottom"
                                      decoration-danger="status == 'empty'"
                                      decoration-warning="status == 'low'"
                                      decoration-info="status == 'overstock'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="product_uom_id"/>
                                    <field name="min_qty"/>
                                    <field name="max_qty"/>
                                    <field name="current_qty"/>
                                    <field name="facing"/>
                                    <field name="planogram_pos" optional="hide"/>
                                    <field name="is_promo"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'ok'"
                                           decoration-warning="status == 'low'"
                                           decoration-danger="status == 'empty'"
                                           decoration-info="status == 'overstock'"/>
                                    <field name="note" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- TREE -->
    <record id="view_display_location_tree" model="ir.ui.view">
        <field name="name">bhx.display.location.tree</field>
        <field name="model">bhx.display.location</field>
        <field name="arch" type="xml">
            <tree string="Vị trí trưng bày">
                <field name="code"/>
                <field name="name"/>
                <field name="zone"/>
                <field name="location_type"/>
                <field name="aisle"/>
                <field name="shelf_no"/>
                <field name="level"/>
                <field name="warehouse_id"/>
                <field name="responsible_id"/>
                <field name="product_count"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- KANBAN -->
    <record id="view_display_location_kanban" model="ir.ui.view">
        <field name="name">bhx.display.location.kanban</field>
        <field name="model">bhx.display.location</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="code"/>
                <field name="zone"/>
                <field name="location_type"/>
                <field name="product_count"/>
                <field name="warehouse_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        <field name="code"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-map-marker"/> <field name="zone"/></div>
                                <div><i class="fa fa-th-large"/> <field name="location_type"/></div>
                                <div><strong><field name="product_count"/> sản phẩm</strong></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <span class="text-muted"><field name="warehouse_id"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_display_location_search" model="ir.ui.view">
        <field name="name">bhx.display.location.search</field>
        <field name="model">bhx.display.location</field>
        <field name="arch" type="xml">
            <search string="Tìm vị trí trưng bày">
                <field name="name"/>
                <field name="code"/>
                <field name="warehouse_id"/>
                <filter string="FMCG" name="fmcg" domain="[('zone','=','fmcg')]"/>
                <filter string="Rau củ" name="fruit_veg" domain="[('zone','=','fruit_veg')]"/>
                <filter string="Fresh / Đông lạnh" name="fresh" domain="[('zone','=','fresh')]"/>
                <separator/>
                <filter string="Không hoạt động" name="inactive" domain="[('active','=',False)]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Khu vực" name="group_zone" context="{'group_by':'zone'}"/>
                    <filter string="Loại vị trí" name="group_type" context="{'group_by':'location_type'}"/>
                    <filter string="Cửa hàng" name="group_warehouse" context="{'group_by':'warehouse_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_display_location" model="ir.actions.act_window">
        <field name="name">Vị trí trưng bày</field>
        <field name="res_model">bhx.display.location</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_display_location_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo vị trí trưng bày đầu tiên!</p>
            <p>Quản lý tất cả kệ, quầy, tủ lạnh và vị trí trưng bày trong cửa hàng.</p>
        </field>
    </record>
</odoo>
