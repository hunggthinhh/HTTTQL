<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_inventory_display" model="ir.module.category">
            <field name="name">BHX Tồn Kho &amp; Trưng Bày</field>
            <field name="sequence">21</field>
        </record>
        <record id="group_inventory_user" model="res.groups">
            <field name="name">Nhân viên tồn kho &amp; trưng bày</field>
            <field name="category_id" ref="module_category_inventory_display"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_inventory_manager" model="res.groups">
            <field name="name">Quản lý tồn kho &amp; trưng bày</field>
            <field name="category_id" ref="module_category_inventory_display"/>
            <field name="implied_ids" eval="[(4, ref('group_inventory_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
