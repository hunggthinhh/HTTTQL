<?xml version="1.0" encoding="utf-8"?>
    <odoo noupdate="1">
        <!-- Các Thẻ Nghiệp Vụ Kanban cho Bách Hóa Xanh -->
        <record id="bhx_dashboard_fmcg" model="bhx.inventory.dashboard">
            <field name="name">Kiểm hàng FMCG</field>
            <field name="code">fmcg</field>
            <field name="sequence">10</field>
            <field name="color">3</field>
        </record>

        <record id="bhx_dashboard_fresh" model="bhx.inventory.dashboard">
            <field name="name">Nhập hàng Tươi sống</field>
            <field name="code">fresh</field>
            <field name="sequence">20</field>
            <field name="color">4</field>
        </record>

        <record id="bhx_dashboard_fruit" model="bhx.inventory.dashboard">
            <field name="name">Lệnh nhập Rau củ</field>
            <field name="code">fruit</field>
            <field name="sequence">30</field>
            <field name="color">5</field>
        </record>

        <record id="bhx_dashboard_replenish" model="bhx.inventory.dashboard">
            <field name="name">Lệnh chuyển hàng lên kệ</field>
            <field name="code">replenish</field>
            <field name="sequence">40</field>
            <field name="color">2</field>
        </record>

        <record id="bhx_dashboard_alert" model="bhx.inventory.dashboard">
            <field name="name">Cảnh báo Tồn / Date</field>
            <field name="code">alert</field>
            <field name="sequence">50</field>
            <field name="color">1</field>
        </record>

        <record id="bhx_dashboard_pos" model="bhx.inventory.dashboard">
            <field name="name">Bán hàng POS</field>
            <field name="code">pos</field>
            <field name="sequence">60</field>
            <field name="color">9</field>
        </record>

        <record id="bhx_dashboard_empty_shelf" model="bhx.inventory.dashboard">
            <field name="name">Xử lý kệ trống</field>
            <field name="code">empty_shelf</field>
            <field name="sequence">55</field>
            <field name="color">10</field>
        </record>

        <!-- Kiểm kê & Kiểm soát & Xử lý hàng -->
        <record id="bhx_dashboard_count" model="bhx.inventory.dashboard">
            <field name="name">Phiếu Kiểm kê</field>
            <field name="code">count</field>
            <field name="sequence">70</field>
            <field name="color">6</field>
        </record>

        <record id="bhx_dashboard_goods_ctrl" model="bhx.inventory.dashboard">
            <field name="name">Kiểm soát cửa hàng</field>
            <field name="code">goods_ctrl</field>
            <field name="sequence">80</field>
            <field name="color">7</field>
        </record>

        <record id="bhx_dashboard_disposal" model="bhx.inventory.dashboard">
            <field name="name">Huỷ &amp; Xử lý hàng</field>
            <field name="code">disposal</field>
            <field name="sequence">90</field>
            <field name="color">8</field>
        </record>
    
</odoo>
