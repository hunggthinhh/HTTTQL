<?xml version="1.0" encoding="utf-8"?>
    <odoo noupdate="1">
        <!-- Sample Stock Alerts -->
        <record id="alert_low_coca" model="bhx.stock.alert">
            <field name="name">SẮP HẾT: Coca-Cola chai 390ml - Kệ A1</field>
            <field name="alert_type">low_stock</field>
            <field name="priority">2</field>
            <field name="product_id" ref="bhx_import_goods.product_coca"/>
            <field name="warehouse_id" ref="bhx_import_goods.bhx_warehouse"/>
            <field name="current_qty">15</field>
            <field name="min_qty">24</field>
            <field name="max_qty">100</field>
            <field name="state">new</field>
        </record>

        <!-- Sample Audit Required Alert -->
        <record id="alert_audit_coca" model="bhx.stock.alert">
            <field name="name">YÊU CẦU KIỂM KÊ: Có chênh lệch lớn</field>
            <field name="alert_type">audit_required</field>
            <field name="priority">3</field>
            <field name="product_id" ref="bhx_import_goods.product_coca"/>
            <field name="warehouse_id" ref="bhx_import_goods.bhx_warehouse"/>
            <field name="current_qty">-5</field>
            <field name="min_qty">24</field>
            <field name="max_qty">100</field>
            <field name="note">Hệ thống ghi nhận tồn kho âm, cần kiểm đếm thực tế khẩn cấp.</field>
            <field name="state">new</field>
        </record>

        <!-- Sample Control Required Alert -->
        <record id="alert_control_coca" model="bhx.stock.alert">
            <field name="name">YÊU CẦU KIỂM SOÁT: Hạn sử dụng</field>
            <field name="alert_type">control_required</field>
            <field name="priority">2</field>
            <field name="product_id" ref="bhx_import_goods.product_coca" />
            <field name="warehouse_id" ref="bhx_import_goods.bhx_warehouse"/>
            <field name="current_qty">10</field>
            <field name="min_qty">5</field>
            <field name="max_qty">20</field>
            <field name="note">Cần kiểm tra HSD của lô hàng trên kệ.</field>
            <field name="state">new</field>
        </record>
    
</odoo>
