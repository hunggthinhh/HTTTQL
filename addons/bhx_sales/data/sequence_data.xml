<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_sales_shift" model="ir.sequence">
            <field name="name">Ca bán hàng</field>
            <field name="code">bhx.sales.shift</field>
            <field name="prefix">CA/%(year)s/%(month)s/%(day)s/</field>
            <field name="padding">2</field>
        </record>
        <record id="seq_sales_order" model="ir.sequence">
            <field name="name">Đơn hàng bán lẻ</field>
            <field name="code">bhx.sales.order</field>
            <field name="prefix">BH/%(year)s/%(month)s/</field>
            <field name="padding">5</field>
        </record>
        <record id="seq_return_request" model="ir.sequence">
            <field name="name">Phiếu đổi/trả hàng</field>
            <field name="code">bhx.return.request</field>
            <field name="prefix">DTH/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
