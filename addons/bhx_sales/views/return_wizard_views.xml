<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bhx_return_wizard_form" model="ir.ui.view">
        <field name="name">bhx.return.wizard.form</field>
        <field name="model">bhx.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Chọn sản phẩm đổi/trả">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Chọn sản phẩm và nhập số lượng khách muốn trả. Chỉ hiển thị sản phẩm còn có thể trả.
                    </div>
                    <group>
                        <field name="order_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="note" placeholder="Nhập lý do đổi/trả (tùy chọn)..."/>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom" create="0" delete="0">
                            <field name="product_id" readonly="1"/>
                            <field name="purchased_qty" readonly="1" string="SL mua"/>
                            <field name="returned_qty" readonly="1" string="Đã trả"/>
                            <field name="available_qty" readonly="1" string="Có thể trả"
                                   decoration-danger="available_qty == 0"/>
                            <field name="return_qty" string="SL trả lần này"
                                   attrs="{'readonly': [('available_qty', '=', 0)]}"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_create_return_request"
                            string="Tạo phiếu yêu cầu"
                            type="object"
                            class="btn-primary"/>
                    <button special="cancel" string="Hủy bỏ" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>