<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM -->
    <record id="view_sales_shift_form" model="ir.ui.view">
        <field name="name">bhx.sales.shift.form</field>
        <field name="model">bhx.sales.shift</field>
        <field name="arch" type="xml">
            <form string="Ca bán hàng">
                <header>
                    <button name="action_open_pos" string="Bán hàng POS" type="object" class="btn-success" invisible="state != 'open'"/>
                    <button name="action_close_shift" string="Đóng ca" type="object" class="btn-danger" invisible="state != 'open'"/>
                    <button name="action_reconcile" string="Đối soát doanh thu" type="object" class="btn-primary" invisible="state != 'closed'" groups="bhx_sales.group_sales_manager"/>

                    <field name="state" widget="statusbar" statusbar_visible="open,closed,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-shopping-cart" type="object" name="action_close_shift">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="total_transactions"/></span>
                                <span class="o_stat_text">Giao dịch</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-money" type="object" name="action_close_shift">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="total_revenue" widget="monetary"/></span>
                                <span class="o_stat_text">Doanh thu</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Thông tin ca">
                            <field name="date"/>
                            <field name="shift_type"/>
                            <field name="warehouse_id"/>
                            <field name="cashier_id"/>
                        </group>
                        <group string="Thời gian &amp; Tiền mặt">
                            <field name="open_time" readonly="1"/>
                            <field name="close_time" readonly="1"/>
                            <field name="opening_cash"/>
                            <field name="expected_cash" readonly="1" widget="monetary" decoration-bf="1" decoration-success="1"/>
                            <field name="closing_cash"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Đơn hàng trong ca" name="orders">
                            <field name="order_ids" readonly="1">
                                <tree decoration-success="state == 'done'" decoration-danger="state == 'refund'">
                                    <field name="name"/>
                                    <field name="date_order"/>
                                    <field name="customer_name"/>
                                    <field name="customer_phone"/>
                                    <field name="payment_method"/>
                                    <field name="total_amount" widget="monetary"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Ghi chú cuối ca" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- TREE -->
    <record id="view_sales_shift_tree" model="ir.ui.view">
        <field name="name">bhx.sales.shift.tree</field>
        <field name="model">bhx.sales.shift</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'reconciled'"
                  decoration-info="state == 'open'"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="date"/>
                <field name="shift_type"/>
                <field name="warehouse_id"/>
                <field name="cashier_id"/>
                <field name="open_time"/>
                <field name="close_time"/>
                <field name="expected_cash" widget="monetary" decoration-bf="1"/>
                <field name="total_transactions"/>
                <field name="total_revenue" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'reconciled'"
                       decoration-info="state == 'open'"
                       decoration-warning="state == 'closed'"/>
            </tree>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_sales_shift_search" model="ir.ui.view">
        <field name="name">bhx.sales.shift.search</field>
        <field name="model">bhx.sales.shift</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="cashier_id"/>
                <field name="warehouse_id"/>
                <filter string="Đang mở ca" name="open" domain="[('state','=','open')]"/>
                <filter string="Đã đóng ca" name="closed" domain="[('state','=','closed')]"/>
                <filter string="Hôm nay" name="today" domain="[('date','=',context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Ca" name="group_shift" context="{'group_by':'shift_type'}"/>
                    <filter string="Cửa hàng" name="group_wh" context="{'group_by':'warehouse_id'}"/>
                    <filter string="Ngày" name="group_date" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sales_shift" model="ir.actions.act_window">
        <field name="name">Ca bán hàng</field>
        <field name="res_model">bhx.sales.shift</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Mở ca bán hàng đầu tiên!</p>
        </field>
    </record>
</odoo>
