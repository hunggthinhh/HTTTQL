<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM -->
    <record id="view_sales_order_form" model="ir.ui.view">
        <field name="name">bhx.sales.order.form</field>
        <field name="model">bhx.sales.order</field>
        <field name="arch" type="xml">
            <form string="Đơn hàng bán lẻ">
                <header>
                    <button name="action_done_and_next" string="Xác nhận &amp; Bán tiếp" type="object" class="btn-success" invisible="state != 'draft'"/>
                    <button name="action_done" string="Xác nhận thanh toán" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Huỷ đơn" type="object" class="btn-danger" invisible="state in ('done','cancel','refund')"/>

                    <button name="action_refund" string="Hoàn hàng" type="object" invisible="state != 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Thông tin đơn hàng">
                            <field name="date_order"/>
                            <field name="shift_id" options="{'no_create': True}"/>
                            <field name="warehouse_id" force_save="1"/>
                            <field name="cashier_id" readonly="1"/>

                            <field name="payment_method"/>
                            <field name="promotion_id"/>
                        </group>
                        <group string="Thông tin khách hàng">
                            <field name="customer_phone"/>
                            <field name="customer_name"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sản phẩm" name="lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="barcode" optional="hide"/>
                                    <field name="product_uom_id"/>
                                    <field name="qty"/>
                                    <field name="unit_price"/>
                                    <field name="discount_pct"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="note" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                    <group>
                        <group/>
                        <group class="oe_subtotal_footer">
                            <field name="subtotal" string="Tạm tính"/>
                            <field name="discount_amount" string="Giảm giá KM"/>
                            <field name="total_amount" string="Thành tiền" widget="monetary"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- TREE -->
    <record id="view_sales_order_tree" model="ir.ui.view">
        <field name="name">bhx.sales.order.tree</field>
        <field name="model">bhx.sales.order</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'done'"
                  decoration-danger="state == 'refund'"
                  decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="date_order"/>
                <field name="shift_id"/>
                <field name="warehouse_id"/>
                <field name="cashier_id"/>
                <field name="customer_name" optional="show"/>
                <field name="payment_method"/>
                <field name="total_amount" widget="monetary"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'done'"
                       decoration-danger="state in ('cancel','refund')"/>
            </tree>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_sales_order_search" model="ir.ui.view">
        <field name="name">bhx.sales.order.search</field>
        <field name="model">bhx.sales.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_phone"/>
                <field name="cashier_id"/>
                <filter string="Hôm nay" name="today"
                        domain="[('date_order', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')),
                                 ('date_order', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
                <filter string="Đã thanh toán" name="done" domain="[('state','=','done')]"/>
                <filter string="Hoàn hàng" name="refund" domain="[('state','=','refund')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Phương thức TT" name="group_payment" context="{'group_by':'payment_method'}"/>
                    <filter string="Cửa hàng" name="group_wh" context="{'group_by':'warehouse_id'}"/>
                    <filter string="Ngày" name="group_date" context="{'group_by':'date_order:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sales_order" model="ir.actions.act_window">
        <field name="name">Đơn hàng bán lẻ</field>
        <field name="res_model">bhx.sales.order</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tạo đơn hàng bán lẻ đầu tiên!</p>
        </field>
    </record>
</odoo>
