<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_bhx" model="ir.ui.view">
        <name>res.config.settings.view.form.inherit.bhx.sales</name>
        <model>res.config.settings</model>
        <priority>99</priority>
        <inherit_id ref="base.res_config_settings_view_form" />
        <arch type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="BHX POS" string="BHX POS" data-key="bhx_sales">
                    <h2>Cấu hình Thanh toán SePay</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Thông tin Ngân hàng (SePay)</span>
                                <div class="text-muted">
                                    Cung cấp thông tin để sinh mã VietQR tự động.
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <label for="sepay_bank_id" class="o_light_label"/>
                                        <field name="sepay_bank_id" placeholder="VD: MB, VCB..."/>
                                    </div>
                                    <div class="mt8">
                                        <label for="sepay_account_no" class="o_light_label"/>
                                        <field name="sepay_account_no"/>
                                    </div>
                                    <div class="mt8">
                                        <label for="sepay_account_name" class="o_light_label"/>
                                        <field name="sepay_account_name"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Bảo mật (API &amp; Webhook)</span>
                                <div class="text-muted">
                                    Kết nối SePay để tự động hóa gạch nợ.
                                </div>
                                <div class="content-group">
                                    <div class="mt16">
                                        <label for="sepay_api_key" class="o_light_label"/>
                                        <field name="sepay_api_key" password="True"/>
                                    </div>
                                    <div class="mt8">
                                        <label for="sepay_webhook_token" class="o_light_label"/>
                                        <field name="sepay_webhook_token" password="True"/>
                                    </div>
                                </div>
                                <div class="mt16">
                                    <a href="https://my.sepay.vn" target="_blank" class="btn-link">
                                        <i class="fa fa-external-link"/> Truy cập SePay Dashboard
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </arch>
    </record>

    <record id="action_bhx_sales_config" model="ir.actions.act_window">
        <name>Settings</name>
        <type>ir.actions.act_window</type>
        <res_model>res.config.settings</res_model>
        <view_mode>form</view_mode>
        <target>inline</target>
        <context>{'module' : 'bhx_sales'}</context>
    </record>
</odoo>
